{
  "name": "codegraph-viewer",
  "displayName": "CodeGraph Viewer",
  "description": "Visualize and navigate code knowledge graphs generated by CodeGraph",
  "version": "0.1.0",
  "publisher": "SantiagoRomanChillon",
  "repository": {
    "type": "git",
    "url": "https://github.com/SantiagoRoChi/Codegraph-Viewer"
  },
  "bugs": {
    "url": "https://github.com/SantiagoRoChi/Codegraph-Viewer/issues"
  },
  "homepage": "https://github.com/SantiagoRoChi/Codegraph-Viewer",
  "license": "MIT",
  "icon": "resources/icon.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Visualization",
    "Other"
  ],
  "keywords": [
    "codegraph",
    "code-intelligence",
    "graph",
    "visualization",
    "knowledge-graph"
  ],
  "main": "./out/extension.js",
  "activationEvents": [
    "onCommand:codegraph.openGraph",
    "onCommand:codegraph.openDbFile",
    "workspaceContains:**/.codegraph/codegraph.db"
  ],
  "contributes": {
    "commands": [
      {
        "command": "codegraph.openGraph",
        "title": "Open CodeGraph",
        "category": "CodeGraph",
        "icon": "$(graph)"
      },
      {
        "command": "codegraph.openGraphFocus",
        "title": "Focus Node in Graph",
        "category": "CodeGraph",
        "icon": "$(target)"
      },
      {
        "command": "codegraph.previewGraph",
        "title": "Preview Graph for Symbol",
        "category": "CodeGraph",
        "icon": "$(eye)"
      },
      {
        "command": "codegraph.search",
        "title": "Search Symbols",
        "category": "CodeGraph",
        "icon": "$(search)"
      },
      {
        "command": "codegraph.refresh",
        "title": "Refresh Graph",
        "category": "CodeGraph",
        "icon": "$(refresh)"
      },
      {
        "command": "codegraph.openNodeDetail",
        "title": "Show Node Details",
        "category": "CodeGraph"
      },
      {
        "command": "codegraph.navigateToNode",
        "title": "Go to Definition",
        "category": "CodeGraph",
        "icon": "$(go-to-file)"
      },
      {
        "command": "codegraph.setDbPath",
        "title": "Set Database Path",
        "category": "CodeGraph"
      },
      {
        "command": "codegraph.openDbFile",
        "title": "Open as CodeGraph Database",
        "category": "CodeGraph",
        "icon": "$(database)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "codegraph",
          "title": "CodeGraph",
          "icon": "resources/activity-icon.svg"
        }
      ]
    },
    "views": {
      "codegraph": [
        {
          "id": "codegraphExplorer",
          "name": "CodeGraph Explorer",
          "icon": "$(symbol-class)"
        },
        {
          "id": "codegraphSearch",
          "name": "Search",
          "icon": "$(search)"
        }
      ]
    },
    "menus": {
      "editor/context": [
        {
          "command": "codegraph.openGraphFocus",
          "when": "editorHasSelection",
          "group": "codegraph@1"
        },
        {
          "command": "codegraph.previewGraph",
          "when": "editorHasSelection",
          "group": "codegraph@2"
        }
      ],
      "commandPalette": [
        {
          "command": "codegraph.openGraph",
          "when": "true"
        },
        {
          "command": "codegraph.search",
          "when": "true"
        },
        {
          "command": "codegraph.refresh",
          "when": "true"
        },
        {
          "command": "codegraph.setDbPath",
          "when": "true"
        }
      ],
      "explorer/context": [
        {
          "command": "codegraph.openDbFile",
          "when": "resourceExtname == .db",
          "group": "codegraph@1"
        }
      ],
      "view/title": [
        {
          "command": "codegraph.refresh",
          "when": "view == codegraphExplorer",
          "group": "navigation"
        },
        {
          "command": "codegraph.search",
          "when": "view == codegraphSearch",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "codegraph.navigateToNode",
          "when": "view == codegraphExplorer && viewItem == node",
          "group": "inline"
        },
        {
          "command": "codegraph.openNodeDetail",
          "when": "view == codegraphExplorer && viewItem == node",
          "group": "inline"
        }
      ]
    },
    "configuration": {
      "title": "CodeGraph Viewer",
      "properties": {
        "codegraph.dbPath": {
          "type": "string",
          "default": ".codegraph/codegraph.db",
          "description": "Relative or absolute path to the codegraph.db file"
        },
        "codegraph.graph.layout": {
          "type": "string",
          "default": "fcose",
          "enum": [
            "fcose",
            "dagre",
            "circle",
            "concentric",
            "breadthfirst"
          ],
          "description": "Default graph layout algorithm"
        },
        "codegraph.graph.autosyncOnCommit": {
          "type": "boolean",
          "default": true,
          "description": "Automatically run 'codegraph sync' on git commit if codegraph is installed"
        },
        "codegraph.graph.nodeLimit": {
          "type": "number",
          "default": 1000,
          "description": "Maximum number of nodes to render in the graph (for performance)"
        },
        "codegraph.graph.showEdgeLabels": {
          "type": "boolean",
          "default": false,
          "description": "Show edge type labels on the graph"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/sql.js": "^1.4.11",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "@vscode/vsce": "^2.22.0",
    "eslint": "^8.56.0",
    "sharp": "^0.34.5",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "cytoscape": "^3.33.4",
    "cytoscape-dagre": "^3.0.0",
    "cytoscape-fcose": "^2.2.0",
    "sql.js": "^1.14.1"
  }
}
